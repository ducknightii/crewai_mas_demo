'role': 'assistant'}, 'index': 0, 'finish_reason': 'stop'}], 'created': 1772077157, 'object': 'chat.completion', 'usage': {'total_tokens': 9332, 'completion_tokens': 1234, 'prompt_tokens': 8098, 'prompt_tokens_details': {'cached_tokens': 0}}}
